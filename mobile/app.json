{
  "expo": {
    "name": "Ghost",
    "slug": "ghost",
    "scheme": "ghost",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#151718"
    },
    "newArchEnabled": true,
    "plugins": [
      "expo-image",
      "expo-audio",
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "https://ghost-chat-backend-hq1v.onrender.com/api/v1",
      "eas": {
        "projectId": "ea2ddf1c-e5d0-4667-a8e6-3f574889d296"
      }
    },
    "android": {
      "package": "com.harshavardhan20006.ghost"
    }
  }
}
